# terraform.tfvars.example
# Copy this to terraform.tfvars and fill in your values

# ============================================================================
# REQUIRED VARIABLES - YOU MUST SET THESE
# ============================================================================

# Your public IP for SSH access (find with: curl -4 ifconfig.me)
# Use -4 so you get IPv4; a plain "curl ifconfig.me" may return IPv6 on v6-enabled networks.
# Must be an IPv4 address in CIDR format with /32 suffix (IPv6 is not supported by the SGs)
localPub_ip = "x.x.x.x/32"

# Name of your existing AWS SSH key pair
# Must already exist in AWS EC2 Console > Key Pairs
ssh_key_name = "rs-rsa-key"

# Path to your SSH private key (.pem file). Used to decrypt the Windows Administrator password.
# This path is relative to the terraform/ subdirectory you run apply from; the key itself
# lives in the repo root.
ssh_private_key_path = "../rs-rsa-key.pem"

# Your redirector domain (apex or subdomain, e.g. yourdomain.tld).
# Direct Access (default): set this to a domain you own, then point its A record
#   at the Redirector Elastic IP after deployment.
# Tunneled Access or IP-only: set to "" (or comment this line out); the redirector
#   then identifies by its public IP.
redirector_domain = "yourdomain.tld"

# ============================================================================
# OPTIONAL VARIABLES - Customize as needed
# ============================================================================

# AWS region for deployment
aws_region = "us-east-1"

# Project name (used for resource tagging)
project_name = "redStack"

# --- vpnTUN routing: off = Direct Access (public internet), on = Tunneled Access to a closed range (HSL/HTB/VL/PG) ---
enable_vpn_tunnel                    = false             # true = tunnel internal hosts to the range through the redirector
enable_redirector_htaccess_filtering = true              # false when tunneling: AV/scanner blocking is not useful in an isolated range
vpn_tunnel_cidrs                     = ["10.10.0.0/16"]  # range target subnet(s); HSL/HTB default, pro labs also 10.13.0.0/16 + 10.129.0.0/16

# Network configuration
use_default_vpc     = false          # Creates a dedicated VPC (recommended)
vpc_cidr            = "10.50.0.0/16" # TeamServer VPC CIDR
redirector_vpc_cidr = "10.60.0.0/16" # Redirector VPC CIDR

# Instance types (adjust based on budget/performance needs)
mythic_instance_type     = "t3.medium"  # 2 vCPU, 4GB RAM
guacamole_instance_type  = "t3.small"   # 2 vCPU, 2GB RAM
windows_instance_type    = "t3.medium"  # 2 vCPU, 4GB RAM
sliver_instance_type     = "t3.medium"  # 2 vCPU, 4GB RAM
havoc_instance_type      = "t3.medium"  # 2 vCPU, 4GB RAM
redirector_instance_type = "t3.small"   # 2 vCPU, 2GB RAM

# Kali operator workstation
# Mode "headless": SSH only via Guacamole. Adds ~$30/mo at t3.medium 24/7 or ~$1/day for short sessions.
# Mode "gui":      XFCE + XRDP via Guacamole. Uses t3.medium by default; bump to t3.large (8 GB) via kali_instance_type if resources are tight.
# Switch from headless to GUI later without redeploy: SSH in, run `sudo kali-go-gui`.
# IMPORTANT: First-time deployment requires AWS Marketplace acceptance for the Kali Linux AMI.
# Visit https://aws.amazon.com/marketplace/pp/prodview-fznsw3f7mq7to and click "Continue to Subscribe"
# (no charge — Kali project's AMIs are publicly shared, EULA accept is one-time per AWS account).
kali_deployment_mode = "headless"
# kali_deployment_mode = "gui"
# kali_instance_type   = ""   # Leave empty to auto-pick (t3.medium for both modes; set "t3.large" for gui if needed)
# kali_volume_size     = 0    # Leave 0 to auto-pick (30 GB headless, 50 GB gui)

# Mythic configuration
enable_mythic_autostart = true  # Auto-start Mythic on boot

# C2 URI prefixes (CDN/cloud-style paths routed through the redirector)
# These are baked into payloads at deploy time. Customize before deploying.
mythic_uri_prefix = "/cdn/media/stream"
sliver_uri_prefix = "/cloud/storage/objects"
havoc_uri_prefix  = "/edge/cache/assets"

# C2 header validation is always enabled. These override the defaults:
# c2_header_name  = "X-Request-ID"  # Header name (default: X-Request-ID)
# c2_header_value = ""              # Token value — leave empty to auto-generate (recommended)


# Optional: Custom tags applied to every AWS resource (instances, SGs, EIPs, etc.)
# Useful for cost tracking, filtering resources in the AWS Console, and billing reports
#
# NOTE: Every resource also receives a "Project" tag automatically set to project_name above.
# To filter a specific deployment in the AWS Console: filter by Project = <project_name>
# For two simultaneous deployments use distinct project_name values (e.g. "redStack" and "redStack-vpnTUN")
# and matching CostCenter tags so you can isolate each deployment in billing and resource views.
tags = {
  Owner      = "Operator"
  CostCenter = "redStack"        # Match this to project_name for per-deployment cost filtering
  Purpose    = "Boot-to-Breach Training Environment"
}

# ============================================================================
# NOTES
# ============================================================================
#
# 1. To get your public IP:
#    curl -4 ifconfig.me
#    (Use -4 to force IPv4. A plain "curl ifconfig.me" can return an IPv6
#     address on v6-enabled networks, which the security groups do not accept.)
#    Then append /32 for CIDR format
#
# 2. To create an SSH key pair in AWS:
#    AWS Console > EC2 > Key Pairs > Create key pair
#    OR via CLI: aws ec2 create-key-pair --key-name rs-rsa-key --query 'KeyMaterial' --output text > ./rs-rsa-key.pem
#
#    Set permissions on the key file:
#    Linux/Mac:
#      chmod 400 ./rs-rsa-key.pem
#    Windows (PowerShell):
#      icacls .\rs-rsa-key.pem /inheritance:r /grant:r "$($env:USERNAME):(F)"
#
# 3. Estimated monthly cost (us-east-1, on-demand pricing):
#
#    Hourly compute mix (Windows AMI bundles license into the rate):
#      2x Linux  t3.medium  (Mythic, Havoc):            $0.0416/hr each
#      3x Linux  t3.small   (Guac, Sliver, Redirector): $0.0208/hr each
#      1x Windows t3.medium (windows):             $0.0608/hr
#      Combined: ~$0.21/hr
#
#    RECOMMENDED: 5-10 hrs/week study + `terraform destroy` between sessions.
#    Pay only for compute hours actively used. No idle EBS or EIP charges.
#      5  hrs/week (~22 hrs/mo): ~$5/mo
#      10 hrs/week (~43 hrs/mo): ~$9/mo
#
#    Tradeoff: each redeploy adds ~30-45 min of setup before the lab is
#    ready (terraform apply + cloud-init + Windows boot + Havoc rebuild
#    from source). In open mode, DNS A records must be re-pointed to the
#    new redirector EIP each redeploy. Mythic/Sliver/Havoc state is
#    destroyed; for training that is usually the point.
#
#    ALTERNATIVE: stop (don't destroy) between sessions. Preserves state
#    and skips rebuilds (~5-10 min boot to resume), but EBS volumes
#    (~$14/mo) and Elastic IPs (~$7/mo) bill 24/7 even when stopped.
#      5  hrs/week + stopped between: ~$26/mo
#      10 hrs/week + stopped between: ~$30/mo
#
#    REFERENCE (all instances running 24/7):
#      Compute ~$151/mo + storage/EIPs ~$21/mo = ~$172/mo
#
#    Data transfer: first 100 GB/mo outbound free, light study use ~$0
#
# 4. To reduce costs (in priority order):
#    - Default: `terraform destroy` after each session, `terraform apply` next time
#    - Or: stop instances when not in use (preserves state, ~$21/mo idle)
#    - Use smaller instance types for short demos
#    - Set a CloudWatch billing alarm in the AWS Billing Console
#
